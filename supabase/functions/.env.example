# Copy to supabase/functions/.env then run:
#   npx supabase functions serve --no-verify-jwt --env-file supabase/functions/.env

# host.docker.internal: from inside the supabase functions container,
# this resolves to the host machine, where our SurrealDB container is bound to localhost:8000
SURREALDB_URL=ws://host.docker.internal:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=clera
SURREALDB_DB=matchmaking
