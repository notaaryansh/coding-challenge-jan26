# Copy this file to .env and fill in the OPENAI_API_KEY.
# The SurrealDB defaults work out of the box with docker-compose.yml.

# SurrealDB connection (dev defaults — fine for local)
SURREALDB_URL=ws://localhost:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=clera
SURREALDB_DB=matchmaking

# LLM provider — bring your own key
OPENAI_API_KEY=sk-...
