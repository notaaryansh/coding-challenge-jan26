{
  "name": "coding-challenge-jan26",
  "version": "0.1.0",
  "private": true,
  "description": "Matchmaking system - apples and oranges",
  "scripts": {
    "db:start": "docker compose up -d surrealdb",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d surrealdb && sleep 2 && pnpm db:seed",
    "db:seed": "node scripts/seed.mjs",
    "setup": "pnpm db:start && sleep 2 && pnpm db:seed",
    "supabase": "supabase",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:functions:serve": "supabase functions serve"
  },
  "dependencies": {
    "surrealdb": "^1.3.2"
  },
  "devDependencies": {
    "supabase": "^2.23.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  }
}
