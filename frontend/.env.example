# Copy to .env.local
SURREALDB_URL=ws://localhost:8000
SURREALDB_USER=root
SURREALDB_PASS=root
SURREALDB_NS=clera
SURREALDB_DB=matchmaking

# Required for /api/match-explanation (LLM match reasoning).
# Optional model override — defaults to gpt-4o-mini.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
